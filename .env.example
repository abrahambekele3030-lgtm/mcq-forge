# mcq-forge environment configuration
# Copy to .env and fill in. NEVER commit the real .env.

# --- LLM provider ---
# Provider to use: "glm" (default, GLM-4.7-Flash via z-ai-web-dev-sdk) or "mock" (offline).
MCQFORGE_PROVIDER=glm

# GLM-4.7-Flash is accessed through the z-ai-web-dev-sdk. The SDK reads its
# credentials from ZAI_API_KEY (and optionally ZAI_BASE_URL).
ZAI_API_KEY=your-zai-api-key-here
# ZAI_BASE_URL=                  # optional, SDK default if unset

# Override the model name (default: glm-4.7-flash).
# MCQFORGE_GLM_MODEL=glm-4.7-flash

# --- Database ---
# SQLite for local/dev. On Render free tier, switch to a free Postgres
# (Neon / Supabase / Render Postgres free) by changing this to a postgres URL
# and updating prisma/schema.prisma datasource provider to "postgresql".
DATABASE_URL="file:./db/custom.db"

# --- Generation defaults ---
# Hard cap on rounds per job (spec safety limit is 50).
MCQFORGE_MAX_ROUNDS=10

# --- Worker ---
# Concurrency is intentionally 1 on free tiers to stay under rate limits.
# Increase only on a paid plan with a higher quota.
MCQFORGE_CONCURRENCY=1
